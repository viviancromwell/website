  }

  .article-image {
    margin: var(--space-lg) 0;
  }

  .article-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-image figcaption {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    text-align: center;
    font-style: italic;
  }






</style>
