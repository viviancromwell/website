---
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import ArticleStats from '../../../components/ArticleStats.astro';

import heroImage from '../../../assets/writings/lemon-lavender-gin/01-lemon-lavender-gin.jpg';
---

<Base title="Lemon Lavender Gin — Vivian Cromwell" activeNav="writings">
  <div class="painting-back">
    <a href="/writings" class="back-link">&larr; Back to Writings</a>
  </div>

  <article class="article" data-pagefind-body>
    <header class="article-header">
      <h1 class="article-title">Lemon Lavender Gin</h1>
      <div class="article-meta">
        <time datetime="2017-05-23">May 23, 2017</time>
        <span class="article-meta-sep">&middot;</span>
        <span class="article-reading-time">2 min read</span>
        <span class="article-meta-sep">&middot;</span>
        <a href="/writings?category=wine-spirits" class="article-category">Wine & Spirits</a>
      </div>
    </header>

    <div class="article-body">
      <figure class="article-image">
        <Image src={heroImage} alt="Lemon Lavender Gin cocktail with lavender blossoms" widths={[600, 900, 1200]} sizes="(max-width: 768px) 100vw, 700px" loading="eager" />
      </figure>

      <p>Lavender blossom in my back yard and I know it will be all gone when I am back.</p>

      <h2>Recipe</h2>

      <h3>Ingredients</h3>

      <ul>
        <li>2 oz St George Botanivore Gin</li>
        <li>0.5 oz lemon juice</li>
        <li>0.75 oz home made lavender syrup</li>
        <li>Dashes of lavender bitters</li>
      </ul>

      <h3>Instruction</h3>

      <p>Shake and strain into a chilled glass with one large ice cube. I actually made some lavender ice cube for extra prettiness. Top with some club soda. I think I am going to make a fizz version as well.</p>
    </div>

    <ArticleStats slug="lemon-lavender-gin" tags={["gin", "cocktails"]} />
  </article>
</Base>

<style>
  .article {
    max-width: 700px;
    margin: 0 auto;
    padding-bottom: var(--space-2xl);
  }

  .article-header {
    text-align: center;
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 5vw, var(--text-3xl));
    font-weight: 400;
    margin: 0;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .article-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .article-meta-sep {
    color: var(--color-text-muted);
  }

  .article-reading-time {
    font-size: var(--text-sm);
  }

  .article-category {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-label);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .article-category:hover {
    color: var(--color-text);
  }

  .article-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    color: var(--color-text-secondary);
  }

  .article-body h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-text);
    margin: var(--space-xl) 0 var(--space-md);
  }

  .article-body h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text);
    margin: var(--space-xl) 0 var(--space-md);
  }

  .article-body p {
    margin: 0 0 var(--space-md);
  }

  .article-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .article-body a:hover {
    color: var(--color-accent-hover);
  }

  .article-image {
    margin: var(--space-lg) 0;
  }

  .article-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-image figcaption {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    text-align: center;
    font-style: italic;
  }






</style>
