---
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import ArticleStats from '../../../components/ArticleStats.astro';

import cocktail from '../../../assets/writings/awakening-the-dead/01-awakening-the-dead.jpg';
---

<Base title="Awakening the Dead — Vivian Cromwell" activeNav="writings">
  <div class="painting-back">
    <a href="/writings" class="back-link">&larr; Back to Writings</a>
  </div>

  <article class="article" data-pagefind-body>
    <header class="article-header">
      <h1 class="article-title">Awakening the Dead</h1>
      <div class="article-meta">
        <time datetime="2019-07-02">July 2, 2019</time>
        <span class="article-meta-sep">&middot;</span>
        <span class="article-reading-time">1 min read</span>
        <span class="article-meta-sep">&middot;</span>
        <a href="/writings?category=wine-spirits" class="article-category">Wine & Spirits</a>
      </div>
    </header>

    <div class="article-body">
      <figure class="article-image">
        <Image src={cocktail} alt="Awakening the Dead cocktail with Chamucos Tequila" widths={[600, 900, 1200]} sizes="(max-width: 768px) 100vw, 700px" loading="eager" />
      </figure>

      <p>2 oz Chamucos Tequila Diablo Blanco<br />
      0.75 oz Ancho Reyes verde<br />
      0.75 oz lime juice<br />
      0.25 oz Luxardo bitter bianco<br />
      0.25 oz agave nectar<br />
      Two chopped dried chile peppers<br />
      2 dashes saline solution<br />
      2 dashes Chamucos hot sauce<br />
      Garnish: mint sprigs and dried chile pepper</p>

      <p>Combine all ingredients, shake and double strain. Enjoy this chilled drink with a bit of heat, happy Friday!</p>
    </div>

    <ArticleStats slug="awakening-the-dead" tags={["tequila", "cocktails", "agave"]} />
  </article>
</Base>

<style>
  .article {
    max-width: 700px;
    margin: 0 auto;
    padding-bottom: var(--space-2xl);
  }

  .article-header {
    text-align: center;
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 5vw, var(--text-3xl));
    font-weight: 400;
    margin: 0;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .article-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .article-meta-sep {
    color: var(--color-text-muted);
  }

  .article-reading-time {
    font-size: var(--text-sm);
  }

  .article-category {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-label);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .article-category:hover {
    color: var(--color-text);
  }

  .article-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    color: var(--color-text-secondary);
  }

  .article-body h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-text);
    margin: var(--space-xl) 0 var(--space-md);
  }

  .article-body h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text);
    margin: var(--space-xl) 0 var(--space-md);
  }

  .article-body p {
    margin: 0 0 var(--space-md);
  }

  .article-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .article-body a:hover {
    color: var(--color-accent-hover);
  }

  .article-image {
    margin: var(--space-lg) 0;
  }

  .article-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-image figcaption {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    text-align: center;
    font-style: italic;
  }






</style>
