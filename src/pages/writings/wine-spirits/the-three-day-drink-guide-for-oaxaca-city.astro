import cuishExterior from '../../../assets/writings/the-three-day-drink-guide-for-oaxaca-city/05-cuish-exterior.jpg';
import cuishInterior from '../../../assets/writings/the-three-day-drink-guide-for-oaxaca-city/06-cuish-interior.jpg';
